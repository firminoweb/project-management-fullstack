{
  "name": "@app/api",
  "version": "0.1.0",
  "private": true,
  "description": "Backend NestJS: API REST de gerenciamento de projetos.",
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/main",
    "start:prod": "node dist/main",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "jest --config ./test/jest.json test/unit",
    "test:watch": "jest --config ./test/jest.json --watch",
    "test:e2e": "jest --config ./test/jest.json test/e2e",
    "test:cov": "jest --config ./test/jest.json --coverage"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "@nestjs/common": "^10.4.0",
    "@nestjs/config": "^3.2.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/platform-express": "^10.4.0",
    "@nestjs/swagger": "^7.4.2",
    "@nestjs/typeorm": "^10.0.2",
    "better-sqlite3": "^11.3.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.20"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.0",
    "@types/better-sqlite3": "^7.6.11",
    "@nestjs/schematics": "^10.1.0",
    "@nestjs/testing": "^10.4.0",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^22.0.0",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "prettier": "^3.3.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.0",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.0"
  }
