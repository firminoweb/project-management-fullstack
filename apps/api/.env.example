# Porta HTTP da API (opcional; padrão 3000)
PORT=3000

# CORS: origem do frontend permitida (opcional; padrão libera todas em dev)
CORS_ORIGIN=http://localhost:5173

# --- Integração com IA (análise inteligente do projeto) ---

# Sem chave configurada, a análise usa o fallback local (mock estruturado).
# ANTHROPIC_API_KEY=

# Modelo usado na análise (opcional; padrão claude-opus-4-8).
# ANTHROPIC_MODEL=claude-haiku-4-5
