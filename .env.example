# Variáveis lidas pelo docker compose (copie para `.env` na raiz).
# O Compose faz a substituição em docker-compose.yml (serviço `api`).
# Sem ANTHROPIC_API_KEY, a análise de IA usa o fallback local.

# Chave da API da Anthropic (Claude). Deixe vazio para usar o fallback.
ANTHROPIC_API_KEY=

# Modelo usado na análise (opcional; padrão claude-opus-4-8).
ANTHROPIC_MODEL=claude-opus-4-8
