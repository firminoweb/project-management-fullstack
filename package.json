{
  "name": "project-management-fullstack",
  "version": "0.1.0",
  "private": true,
  "description": "Aplicação web para gerenciamento simplificado de projetos (CRUD, status, risco automático e análise com IA).",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:api": "yarn workspace @app/api dev",
    "dev:web": "yarn workspace @app/web dev",
    "build:api": "yarn workspace @app/api build",
    "build:web": "yarn workspace @app/web build",
    "test:api": "yarn workspace @app/api test"
  }
}
